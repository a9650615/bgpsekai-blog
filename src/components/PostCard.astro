---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import tagsData from '../data/tags.json';
import { url } from '../utils/url.ts';
import { tagStyle } from '../utils/tagColor.ts';

interface TagRecord {
  slug: string;
  originalSlug: string;
  name: string;
  description?: string;
}

interface Props {
  entry: CollectionEntry<'posts'>;
  variant?: 'default' | 'wide';
}

const { entry, variant = 'default' } = Astro.props;
const { title, pubDate, author, excerpt, featureImage, tags } = entry.data;
const href = url(`/${entry.slug}/`);

const dateStr = pubDate.toLocaleDateString('zh-TW', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const charCount = (excerpt ?? title).length;
const readingTime = Math.max(1, Math.ceil(charCount / 500));

const tagsBySlug = new Map<string, TagRecord>(
  (tagsData as TagRecord[]).map((t) => [t.slug, t]),
);
const primaryTagSlug = tags?.[0];
const primaryTagLabel = primaryTagSlug
  ? tagsBySlug.get(primaryTagSlug)?.name ?? primaryTagSlug
  : null;
---

<article class:list={['post-card', variant === 'wide' && 'post-card--wide']}>
  <a href={href} class="post-card__link" aria-label={title}>
    {featureImage && typeof featureImage !== 'string' && (
      <div class="post-card__media">
        <Image
          src={featureImage}
          alt=""
          width={variant === 'wide' ? 960 : 600}
          height={variant === 'wide' ? 540 : 338}
          loading="lazy"
          decoding="async"
        />
        {primaryTagSlug && primaryTagLabel && (
          <span class="post-card__tag-flag" style={tagStyle(primaryTagSlug)}>
            {primaryTagLabel}
          </span>
        )}
      </div>
    )}
    <div class="post-card__body">
      <h2 class="post-card__title">{title}</h2>
      {excerpt && <p class="post-card__excerpt">{excerpt}</p>}
      <div class="post-card__meta">
        <span class="post-card__author">{author}</span>
        <span class="post-card__sep">·</span>
        <time datetime={pubDate.toISOString()}>{dateStr}</time>
        <span class="post-card__sep">·</span>
        <span>{readingTime} min</span>
      </div>
    </div>
  </a>
</article>
