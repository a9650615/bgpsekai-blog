---
// Home-page hero, Casper style. Renders the site title + tagline at full width.
// If a `cover` ImageMetadata is provided, it's rendered as the hero background
// (typically the latest post's featureImage). Otherwise, the no-picture variant
// is applied and CSS handles a coverless presentation.
//
// The site title is always shown — there is no separate featured-post card.
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { url } from '../utils/url.ts';

interface Props {
  /** 用來當背景的圖片 (通常是最新一篇的 featureImage)。可以是 ImageMetadata、string,或省略。 */
  cover?: ImageMetadata | string;
  title?: string;
  description?: string;
  bigger?: boolean;
}

const {
  cover,
  title = '柏狗屁世界',
  description = '你的鳥世界',
  bigger = false,
} = Astro.props;

const hasPictureCover = !!cover && typeof cover !== 'string';
---

<section class:list={['hero', hasPictureCover ? 'hero--with-picture' : 'hero--no-picture']}>
  {hasPictureCover && (
    <div class="hero__picture">
      <Image
        src={cover as ImageMetadata}
        alt=""
        width={1920}
        height={900}
        loading="eager"
        decoding="async"
      />
    </div>
  )}
  <div class="hero__content l-wrap">
    <h1 class:list={['hero__title', { 'is-bigger': bigger }]}>{title}</h1>
    <p class="hero__description">{description}</p>
    <div class="hero__cta">
      <a href={url('/rss.xml')} class="hero__btn hero__btn--ghost">訂 RSS</a>
      <a href="#latest" class="hero__btn hero__btn--solid">看最新文章 ↓</a>
    </div>
  </div>
</section>
