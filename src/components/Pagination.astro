---
// Pagination — list-page nav for paginated indexes (home, /page/N/, tag, ...).
//
// `basePath` must end with a trailing slash, e.g. `/`, `/tag/foo/`. Page 1
// resolves to `basePath`; pages 2..N to `${basePath}page/N/`.
//
// We render: prev · 1 2 … N · next, with simple ellipsis when the page count
// is large. Markup is flat (`<a>` / `<span class="is-current">`) to match the
// `.pagination a` / `.pagination .is-current` rules in global.css.

interface Props {
  currentPage: number;
  totalPages: number;
  basePath: string;
}

const { currentPage, totalPages, basePath } = Astro.props;

function pageHref(n: number): string {
  if (n <= 1) return basePath;
  return `${basePath}page/${n}/`;
}

const prev = currentPage > 1 ? pageHref(currentPage - 1) : null;
const next = currentPage < totalPages ? pageHref(currentPage + 1) : null;

// Build page-number list with simple ellipsis (window of 1 around current,
// always include 1 and totalPages).
function buildList(current: number, total: number): Array<number | '…'> {
  if (total <= 7) {
    return Array.from({ length: total }, (_, i) => i + 1);
  }
  const set = new Set<number>([1, total, current - 1, current, current + 1]);
  const sorted = [...set].filter((n) => n >= 1 && n <= total).sort((a, b) => a - b);
  const out: Array<number | '…'> = [];
  for (let i = 0; i < sorted.length; i++) {
    out.push(sorted[i]);
    if (i < sorted.length - 1 && sorted[i + 1] - sorted[i] > 1) {
      out.push('…');
    }
  }
  return out;
}

const items = totalPages > 1 ? buildList(currentPage, totalPages) : [];
---

{totalPages > 1 && (
  <nav class="pagination" aria-label="分頁">
    {prev ? (
      <a href={prev} rel="prev">← 上一頁</a>
    ) : (
      <span aria-disabled="true">← 上一頁</span>
    )}

    {items.map((it) =>
      it === '…' ? (
        <span aria-hidden="true">…</span>
      ) : it === currentPage ? (
        <span class="is-current" aria-current="page">{it}</span>
      ) : (
        <a href={pageHref(it)}>{it}</a>
      )
    )}

    {next ? (
      <a href={next} rel="next">下一頁 →</a>
    ) : (
      <span aria-disabled="true">下一頁 →</span>
    )}
  </nav>
)}
