---
import tagsData from '../data/tags.json';
import { url } from '../utils/url.ts';

interface TagRecord {
  slug: string;
  originalSlug: string;
  name: string;
  description?: string;
}

interface Props {
  author: string;
  pubDate: Date;
  tags?: string[];
  /** Approximate character count of the rendered body (CN ≈ 500/min). */
  charCount?: number;
}

const { author, pubDate, tags = [], charCount } = Astro.props;

const tagsBySlug = new Map<string, TagRecord>(
  (tagsData as TagRecord[]).map((t) => [t.slug, t]),
);

const dateStr = pubDate.toLocaleDateString('zh-TW', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const readingTime = charCount ? Math.max(1, Math.ceil(charCount / 500)) : null;
---

<div class="post-meta">
  <div class="post-meta__byline">
    <a class="post-meta__author" href={url(`/author/${author}/`)} rel="author">{author}</a>
    <span class="post-meta__sep">•</span>
    <time datetime={pubDate.toISOString()}>{dateStr}</time>
    {readingTime !== null && (
      <>
        <span class="post-meta__sep">•</span>
        <span class="post-meta__reading">{readingTime} min read</span>
      </>
    )}
  </div>

  {tags.length > 0 && (
    <ul class="post-meta__tags" aria-label="標籤">
      {tags.map((slug) => {
        const t = tagsBySlug.get(slug);
        const label = t?.name ?? slug;
        return (
          <li>
            <a class="post-meta__tag" href={url(`/tag/${slug}/`)}>{label}</a>
          </li>
        );
      })}
    </ul>
  )}
</div>
