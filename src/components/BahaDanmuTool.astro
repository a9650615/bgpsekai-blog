---
// Baha 彈幕 → ASS 工具 UI shell.
// This is a static fragment; behaviour is provided by the colocated client
// script `BahaDanmuTool.client.ts`, loaded as an ES module script tag.
---

<section class="baha-danmu-tool" data-baha-danmu-tool aria-labelledby="baha-tool-heading">
  <h1 id="baha-tool-heading">巴哈動漫瘋彈幕轉 ASS 工具</h1>

  <p class="baha-danmu-tool__hint">
    將動漫瘋影片頁網址 (含 <code>sn=</code>) 或純 SN 數字貼到下方輸入框,按「取得」即可下載 ASS 字幕。
    範例: <code>https://ani.gamer.com.tw/animeVideo.php?sn=15577</code>
  </p>

  <form class="baha-danmu-tool__form" onsubmit="return false;">
    <label class="baha-danmu-tool__field">
      <span>網址或 SN</span>
      <input
        id="baha-param"
        name="param"
        type="text"
        placeholder="請輸入網站網址或者 sn ID"
        autocomplete="off"
        spellcheck="false"
      />
    </label>

    <label class="baha-danmu-tool__field baha-danmu-tool__field--narrow">
      <span>時間差 (秒)</span>
      <input id="baha-offset" name="offset" type="number" value="0" step="1" />
    </label>

    <button id="baha-get" type="button" class="baha-danmu-tool__submit">取得</button>
  </form>

  <p class="baha-danmu-tool__progress">
    <span>進度狀態:</span>
    <span id="baha-status" data-status="idle"></span>
  </p>

  <p id="baha-error" class="baha-danmu-tool__error" role="alert" hidden></p>

  <p class="baha-danmu-tool__download-row">
    <a id="baha-download" class="baha-danmu-tool__download" hidden>下載 ASS</a>
  </p>

  <section class="baha-danmu-tool__notes">
    <h2>使用說明</h2>
    <ul>
      <li>建議搭配 PotPlayer 並將彈幕字幕拖進第二字幕。</li>
      <li>本工具透過第三方 <code>corsproxy.io</code> 中繼存取巴哈 API,該服務若停擺工具會無法運作。</li>
      <li>新版巴哈 API 限制非登入用戶取得完整彈幕,因此部份較新動畫可能拿到空陣列。</li>
    </ul>
  </section>
</section>

<script>
  // Hydrate the tool. Astro's bundler will compile and inject this for us.
  import '../components/BahaDanmuTool.client.ts';
</script>

<style>
  .baha-danmu-tool {
    max-width: 720px;
    margin: 2rem auto;
    padding: 1.5rem;
    line-height: 1.6;
  }

  .baha-danmu-tool h1 {
    margin: 0 0 0.5rem;
    color: var(--titles-color);
    font-size: 1.5rem;
  }

  .baha-danmu-tool__hint {
    color: var(--primary-foreground-color);
    font-size: 0.95rem;
    margin: 0 0 1.25rem;
  }
  .baha-danmu-tool__hint code {
    background: var(--secondary-subtle-color);
    color: var(--link-color);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    font-size: 0.85em;
  }

  .baha-danmu-tool__form {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: flex-end;
    margin-bottom: 1rem;
    padding: 1.25rem;
    background: var(--secondary-subtle-color);
    border: 1px solid var(--secondary-border-color);
    border-radius: var(--radius, 8px);
  }
  .baha-danmu-tool__field {
    display: flex;
    flex-direction: column;
    flex: 1 1 240px;
  }
  .baha-danmu-tool__field--narrow {
    flex: 0 0 140px;
  }
  .baha-danmu-tool__field span {
    font-size: 0.85rem;
    color: var(--primary-foreground-color);
    font-weight: 600;
    margin-bottom: 0.35rem;
  }
  .baha-danmu-tool__field input {
    padding: 0.6rem 0.75rem;
    border: 1px solid var(--primary-border-color);
    border-radius: var(--radius, 8px);
    font-size: 1rem;
    box-sizing: border-box;
    width: 100%;
    background: var(--background-color);
    color: var(--secondary-foreground-color);
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }
  .baha-danmu-tool__field input:focus {
    outline: none;
    border-color: var(--primary-subtle-color);
    box-shadow: 0 0 0 3px rgba(4, 174, 238, 0.18);
  }

  .baha-danmu-tool__submit {
    padding: 0.6rem 1.5rem;
    background: var(--primary-subtle-color);
    color: #fff;
    border: none;
    border-radius: var(--radius, 8px);
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    flex: 0 0 auto;
    transition: background 0.15s ease, transform 0.1s ease;
  }
  .baha-danmu-tool__submit:hover:not(:disabled) {
    background: var(--link-color);
    transform: translateY(-1px);
  }
  .baha-danmu-tool__submit:disabled {
    background: var(--primary-border-color);
    cursor: not-allowed;
  }

  .baha-danmu-tool__progress {
    margin: 0.75rem 0;
    color: var(--primary-foreground-color);
  }
  #baha-status[data-status='error'] { color: #b00020; font-weight: bold; }
  #baha-status[data-status='done']  { color: #1b6e1b; font-weight: bold; }

  .baha-danmu-tool__error {
    margin: 0.5rem 0;
    padding: 0.6rem 0.8rem;
    border-left: 4px solid #b00020;
    background: #fbeaea;
    color: #690012;
    border-radius: 0 var(--radius, 8px) var(--radius, 8px) 0;
  }

  .baha-danmu-tool__download-row { margin: 1rem 0; }
  .baha-danmu-tool__download {
    display: inline-block;
    padding: 0.55rem 1.2rem;
    background: #1b6e1b;
    color: #fff;
    text-decoration: none;
    border-radius: var(--radius, 8px);
    font-weight: 600;
    transition: background 0.15s ease;
  }
  .baha-danmu-tool__download:hover { background: #258025; }

  .baha-danmu-tool__notes {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--secondary-border-color);
    font-size: 0.95rem;
    color: var(--primary-foreground-color);
  }
  .baha-danmu-tool__notes h2 {
    font-size: 1.1rem;
    margin: 0 0 0.5rem;
    color: var(--titles-color);
  }
  .baha-danmu-tool__notes code {
    background: var(--secondary-subtle-color);
    padding: 0.1em 0.35em;
    border-radius: 4px;
    font-size: 0.9em;
  }
</style>
