---
// /<slug>/ — single post page.
//
// Spec ref: blog-rendering "Render every post and page" + "Casper-ish layout
// fidelity" (cover hero → title → byline → body → tag chips → older/newer).
//
// IMPORTANT: Astro 5 `type: 'content'` strips frontmatter `slug` from data and
// exposes it as `entry.slug`. See src/content/config.ts.
import type { GetStaticPaths } from 'astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Giscus from '../components/Giscus.astro';
import tagsData from '../data/tags.json';
import { tagStyle } from '../utils/tagColor.ts';
import { url } from '../utils/url.ts';

interface TagRecord {
  slug: string;
  originalSlug: string;
  name: string;
  description?: string;
}

export const getStaticPaths = (async () => {
  const posts = await getCollection('posts');
  return posts.map((p) => ({
    params: { slug: p.slug },
    props: { entry: p },
  }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props;
const { title, pubDate, author, tags, featureImage, excerpt, metaTitle, metaDescription } =
  entry.data;

// Older / Newer neighbours (by pubDate desc).
const all = (await getCollection('posts')).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);
const idx = all.findIndex((p) => p.slug === entry.slug);
const newer = idx > 0 ? all[idx - 1] : null;
const older = idx >= 0 && idx < all.length - 1 ? all[idx + 1] : null;

const { Content } = await entry.render();
// reading-time hint via body length (approx, CN-leaning).
const charCount = entry.body?.length;
const readingTime = charCount ? Math.max(1, Math.ceil(charCount / 500)) : null;

const dateStr = pubDate.toLocaleDateString('zh-TW', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const tagsBySlug = new Map<string, TagRecord>(
  (tagsData as TagRecord[]).map((t) => [t.slug, t]),
);

// TODO: data.canonicalUrl is currently unused (0 posts set it). When/if a post
// declares an external canonicalUrl, BaseLayout would need an override prop or
// a head <slot> consumer here. Surfacing it as a TODO per task brief.
const pageTitle = metaTitle ?? title;
const pageDescription = metaDescription ?? excerpt;

const hasCover = featureImage && typeof featureImage !== 'string';
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalPath={`/${entry.slug}/`}
  featureImage={featureImage}
  ogType="article"
  publishDate={pubDate}
>
  <section
    class:list={[
      'hero',
      'post-page__hero',
      hasCover ? 'hero--with-picture' : 'hero--no-picture',
    ]}
  >
    {hasCover && (
      <div class="hero__picture">
        <Image
          src={featureImage}
          alt=""
          width={1920}
          height={900}
          loading="eager"
          decoding="async"
        />
      </div>
    )}
    <div class="hero__content l-wrap">
      <h1 class="hero__title is-bigger">{title}</h1>
      <div class="hero__inner-meta">
        <a href={url(`/author/${author}/`)} rel="author">{author}</a>
        <span>•</span>
        <time datetime={pubDate.toISOString()}>{dateStr}</time>
        {readingTime !== null && (
          <>
            <span>•</span>
            <span>{readingTime} min read</span>
          </>
        )}
      </div>
    </div>
  </section>

  <article class="post-page l-wrap">
    {tags && tags.length > 0 && (
      <ul class="post-meta__tags" aria-label="標籤">
        {tags.map((slug) => {
          const t = tagsBySlug.get(slug);
          const label = t?.name ?? slug;
          return (
            <li>
              <a
                class="post-meta__tag"
                href={url(`/tag/${slug}/`)}
                style={tagStyle(slug)}
              >{label}</a>
            </li>
          );
        })}
      </ul>
    )}

    <div class="prose post-page__body">
      <Content />
    </div>

    <Giscus />

    <nav class="post-page__nav" aria-label="文章導覽">
      {older ? (
        <a class="post-page__nav-link post-page__nav-link--older" href={url(`/${older.slug}/`)}>
          <span class="post-page__nav-label">← 較舊文章</span>
          <span class="post-page__nav-title">{older.data.title}</span>
        </a>
      ) : <span />}
      {newer ? (
        <a class="post-page__nav-link post-page__nav-link--newer" href={url(`/${newer.slug}/`)}>
          <span class="post-page__nav-label">較新文章 →</span>
          <span class="post-page__nav-title">{newer.data.title}</span>
        </a>
      ) : <span />}
    </nav>
  </article>
</BaseLayout>
