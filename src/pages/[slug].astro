---
// /<slug>/ — single post page.
//
// Spec ref: blog-rendering "Render every post and page" + "Casper-ish layout
// fidelity" (cover → title → byline → body → tag chips → older/newer).
//
// IMPORTANT: Astro 5 `type: 'content'` strips frontmatter `slug` from data and
// exposes it as `entry.slug`. See src/content/config.ts.
import type { GetStaticPaths } from 'astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostMeta from '../components/PostMeta.astro';

export const getStaticPaths = (async () => {
  const posts = await getCollection('posts');
  return posts.map((p) => ({
    params: { slug: p.slug },
    props: { entry: p },
  }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props;
const { title, pubDate, author, tags, featureImage, excerpt, metaTitle, metaDescription } =
  entry.data;

// Older / Newer neighbours (by pubDate desc).
const all = (await getCollection('posts')).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);
const idx = all.findIndex((p) => p.slug === entry.slug);
const newer = idx > 0 ? all[idx - 1] : null;
const older = idx >= 0 && idx < all.length - 1 ? all[idx + 1] : null;

const { Content } = await entry.render();
// reading-time hint via body length (approx, CN-leaning).
const charCount = entry.body?.length;

// TODO: data.canonicalUrl is currently unused (0 posts set it). When/if a post
// declares an external canonicalUrl, BaseLayout would need an override prop or
// a head <slot> consumer here. Surfacing it as a TODO per task brief.
const pageTitle = metaTitle ?? title;
const pageDescription = metaDescription ?? excerpt;
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalPath={`/${entry.slug}/`}
  featureImage={featureImage}
  ogType="article"
  publishDate={pubDate}
  showGiscus={true}
>
  <article class="post-page l-wrap">
    {featureImage && typeof featureImage !== 'string' && (
      <figure class="post-page__cover">
        <Image
          src={featureImage}
          alt=""
          width={1200}
          height={675}
          loading="eager"
          decoding="async"
        />
      </figure>
    )}

    <header class="post-page__header">
      <h1 class="post-page__title">{title}</h1>
      <PostMeta author={author} pubDate={pubDate} tags={tags} charCount={charCount} />
    </header>

    <div class="prose post-page__body">
      <Content />
    </div>

    <nav class="post-page__nav" aria-label="文章導覽">
      {older ? (
        <a class="post-page__nav-link post-page__nav-link--older" href={`/${older.slug}/`}>
          <span class="post-page__nav-label">← 較舊文章</span>
          <span class="post-page__nav-title">{older.data.title}</span>
        </a>
      ) : <span />}
      {newer ? (
        <a class="post-page__nav-link post-page__nav-link--newer" href={`/${newer.slug}/`}>
          <span class="post-page__nav-label">較新文章 →</span>
          <span class="post-page__nav-title">{newer.data.title}</span>
        </a>
      ) : <span />}
    </nav>
  </article>
</BaseLayout>

<style>
  .post-page {
    padding: 2rem 0 3rem;
  }
  .post-page__cover {
    margin: 0 0 1.5rem;
  }
  .post-page__cover img {
    width: 100%;
    height: auto;
    border-radius: 6px;
  }
  .post-page__header {
    margin-bottom: 2rem;
  }
  .post-page__title {
    font-size: clamp(1.6rem, 3.5vw, 2.4rem);
    line-height: 1.25;
    margin: 0 0 0.75rem;
  }
  .post-page__nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    border-top: 1px solid var(--fg-muted, #ddd);
    padding-top: 1.5rem;
    margin-top: 2.5rem;
  }
  .post-page__nav-link {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 0.75rem;
    border-radius: 4px;
    text-decoration: none;
  }
  .post-page__nav-link--newer {
    text-align: right;
    align-items: flex-end;
  }
  .post-page__nav-label {
    font-size: 0.8em;
    color: var(--fg-muted, #888);
  }
  .post-page__nav-title {
    font-weight: 600;
  }
  @media (max-width: 640px) {
    .post-page__nav {
      grid-template-columns: 1fr;
    }
    .post-page__nav-link--newer {
      text-align: left;
      align-items: flex-start;
    }
  }
</style>
