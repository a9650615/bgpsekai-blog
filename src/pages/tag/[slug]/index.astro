---
// /tag/<slug>/ — tag index, page 1.
//
// Spec ref: blog-rendering "Tag and author indexes" — render an index per tag
// with at least one post; display name (zh) shown as heading; URL uses Pinyin
// `slug`. Posts ordered by pubDate descending.
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PostCard from '../../../components/PostCard.astro';
import Pagination from '../../../components/Pagination.astro';
import tagsData from '../../../data/tags.json';

interface TagRecord {
  slug: string;
  originalSlug: string;
  name: string;
  description?: string;
}

export const getStaticPaths = (async () => {
  const POSTS_PER_PAGE = 10;
  const tags = tagsData as TagRecord[];
  const allPosts = (await getCollection('posts')).sort(
    (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
  );
  return tags
    .map((tag) => {
      const posts = allPosts.filter((p) => p.data.tags.includes(tag.slug));
      if (posts.length === 0) return null;
      const totalPages = Math.max(1, Math.ceil(posts.length / POSTS_PER_PAGE));
      return {
        params: { slug: tag.slug },
        props: {
          tag,
          posts: posts.slice(0, POSTS_PER_PAGE),
          totalPages,
        },
      };
    })
    .filter((x): x is NonNullable<typeof x> => x !== null);
}) satisfies GetStaticPaths;

const { tag, posts, totalPages } = Astro.props;
---

<BaseLayout
  title={`標籤:${tag.name} - 柏狗屁世界`}
  description={tag.description ?? `所有「${tag.name}」相關文章。`}
  canonicalPath={`/tag/${tag.slug}/`}
  ogType="website"
>
  <div class="l-wrap">
    <header class="tag-page__header">
      <h1 class="tag-page__title">{tag.name}</h1>
      {tag.description && <p class="tag-page__desc">{tag.description}</p>}
    </header>
    <section class="post-grid">
      {posts.map((p) => <PostCard entry={p} />)}
    </section>
    <Pagination currentPage={1} totalPages={totalPages} basePath={`/tag/${tag.slug}/`} />
  </div>
</BaseLayout>

<style>
  .tag-page__header {
    padding: 2rem 0 0.5rem;
  }
  .tag-page__title {
    margin: 0 0 0.25rem;
  }
  .tag-page__desc {
    color: var(--fg-muted, #666);
    margin: 0;
  }
</style>
