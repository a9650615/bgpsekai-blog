---
// /about-me/ — content-collection page. Carries Giscus so visitors have a
// place to leave site-wide feedback (not just per-post).
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Giscus from '../components/Giscus.astro';

const pages = await getCollection('pages');
const entry = pages.find((p) => p.slug === 'about-me');
if (!entry) {
  throw new Error('about-me page entry not found in pages collection');
}

const { Content } = await entry.render();
const { title, excerpt, featureImage } = entry.data;
---

<BaseLayout
  title={title}
  description={excerpt}
  canonicalPath="/about-me/"
  ogType="website"
>
  <Hero
    title={title}
    description={excerpt}
    cover={featureImage}
    showCta={false}
  />

  <div class="l-wrap">
    <div class="prose">
      <Content />
    </div>

    <Giscus />
  </div>
</BaseLayout>
