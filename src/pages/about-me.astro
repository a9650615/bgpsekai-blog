---
// /about-me/ — content-collection page (NOT a post → no Giscus).
//
// Spec ref: blog-rendering "Content page route renders" + url-and-integrations
// "Comments hidden elsewhere" (Giscus only on posts).
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';

const pages = await getCollection('pages');
const entry = pages.find((p) => p.slug === 'about-me');
if (!entry) {
  throw new Error('about-me page entry not found in pages collection');
}

const { Content } = await entry.render();
const { title, excerpt, featureImage } = entry.data;
---

<BaseLayout
  title={title}
  description={excerpt}
  canonicalPath="/about-me/"
  ogType="website"
  showGiscus={false}
>
  <Hero
    title={title}
    description={excerpt}
    cover={featureImage}
    showCta={false}
  />

  <div class="l-wrap">
    <div class="prose">
      <Content />
    </div>
  </div>
</BaseLayout>
