---
// Home — paginated post listing, page 1 (latest 10 posts).
//
// Spec ref: blog-rendering "Paginated home". Page 1 is served at `/`; pages
// 2..N are owned by `src/pages/page/[page].astro`.
//
// Implementation: rather than `paginate()` (which would also try to emit
// /page/1/ as an alias), we hand-slice the first 10 posts here so the URL
// space stays clean. Latest post is rendered as the Hero feature; posts 2-10
// fill the grid below.
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import PostCard from '../components/PostCard.astro';
import Pagination from '../components/Pagination.astro';
import { url } from '../utils/url.ts';

const POSTS_PER_PAGE = 10;

const all = (await getCollection('posts')).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);

const totalPages = Math.max(1, Math.ceil(all.length / POSTS_PER_PAGE));
const [feature, ...rest] = all.slice(0, POSTS_PER_PAGE);
---

<BaseLayout
  title="柏狗屁世界"
  description="柏狗屁世界 — 雜談、筆記、踩雷與作品。"
  canonicalPath="/"
  ogType="website"
>
  {feature && <Hero feature={feature} />}

  <div class="l-wrap" id="latest">
    <h2 class="section-title">最新文章</h2>
    <section class="post-grid">
      {rest.map((post) => <PostCard entry={post} />)}
    </section>
    <Pagination currentPage={1} totalPages={totalPages} basePath={url('/')} />
  </div>
</BaseLayout>
