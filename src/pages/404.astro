---
// 404 — not found.
//
// Static 404 page; Cloudflare Pages serves this for unmatched URLs.
// Pagefind UI in the header is also available for users to recover.
import BaseLayout from '../layouts/BaseLayout.astro';
import { url } from '../utils/url.ts';
---

<BaseLayout
  title="找不到頁面 - 柏狗屁世界"
  description="找不到指定的頁面。"
  canonicalPath="/404/"
  ogType="website"
  showGiscus={false}
>
  <div class="l-wrap notfound">
    <h1 class="notfound__title">404</h1>
    <p class="notfound__msg">這裡沒有東西。也許頁面已被搬走、刪除,或者你輸錯網址了。</p>
    <p class="notfound__actions">
      <a class="notfound__link" href={url('/')}>回首頁</a>
    </p>
    <p class="notfound__hint">
      你也可以使用頁首的搜尋框找找看。
    </p>
  </div>
</BaseLayout>

<style>
  .notfound {
    text-align: center;
    padding: 4rem 1rem;
  }
  .notfound__title {
    font-size: clamp(3rem, 12vw, 6rem);
    margin: 0 0 1rem;
    color: var(--accent, #19185d);
  }
  .notfound__msg {
    font-size: 1.05rem;
    margin: 0 0 1.5rem;
  }
  .notfound__actions {
    margin: 0 0 1rem;
  }
  .notfound__link {
    display: inline-block;
    padding: 0.6rem 1.25rem;
    border-radius: 4px;
    background: var(--accent, #19185d);
    color: #fff;
    text-decoration: none;
  }
  .notfound__hint {
    color: var(--fg-muted, #888);
    font-size: 0.9em;
  }
</style>
