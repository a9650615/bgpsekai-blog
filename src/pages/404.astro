---
// 404 — not found.
//
// Static 404 page; Cloudflare Pages serves this for unmatched URLs.
// Pagefind UI in the header is also available for users to recover.
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import { url } from '../utils/url.ts';
---

<BaseLayout
  title="找不到頁面 - 柏狗屁世界"
  description="找不到指定的頁面。"
  canonicalPath="/404/"
  ogType="website"
>
  <Hero
    title="404"
    description="這裡沒有東西。也許頁面已被搬走、刪除,或者你輸錯網址了。"
    showCta={false}
  />

  <div class="l-wrap">
    <h2 class="section-title">回到正軌</h2>
    <div class="prose">
      <p>
        <a href={url('/')}>回首頁</a>
      </p>
      <p>你也可以使用頁首的搜尋框找找看。</p>
    </div>
  </div>
</BaseLayout>
