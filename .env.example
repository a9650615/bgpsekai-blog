# Copy to `.env` for local development. `.env` is gitignored.
# Production values live in GitHub Actions secrets, see
# .github/workflows/deploy.yml for the wiring.

# --- Analytics ---

# GA4 measurement id, `G-XXXXXXXXXX`. BaseLayout skips the gtag injection
# when this is undefined, so leaving it blank locally is fine. Production
# value lives in repo secret `PUBLIC_GA4_MEASUREMENT_ID`.
PUBLIC_GA4_MEASUREMENT_ID=

# Cloudflare Web Analytics beacon token. Phase 2 only — not yet wired into
# BaseLayout. Uncomment once §9.3.P2 lands.
# PUBLIC_CF_BEACON_TOKEN=

# --- Build overrides (rarely needed) ---

# Astro `site` / `base` override. Used by the GitHub Pages preview workflow
# to publish under `/bgpsekai-blog/`. Production CF deploy leaves both unset.
# SITE_URL=https://blog.bgpsekai.club
# BASE_PATH=/

# --- Ghost import (one-shot, local only) ---

# Only needed to re-run `scripts/ghost-export.ts` and regenerate
# `import-cache/`. Not used by `npm run build` or by deploy. After the Ghost
# site is shut down (post §12 cutover) these become irrelevant.
# GHOST_URL=https://blog.bgpsekai.club
# GHOST_CONTENT_KEY=
# GHOST_ADMIN_KEY=
